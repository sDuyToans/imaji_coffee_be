POST http://localhost:8080/api/v1/order
Content-Type: application/json
Accept: application/json

{
  "userId": 1,
  "email": "john.doe@example.com",
  "shippingAddress": {
    "name": "John Doe",
    "country": "US",
    "province": "California",
    "city": "Los Angeles",
    "postalCode": "90001",
